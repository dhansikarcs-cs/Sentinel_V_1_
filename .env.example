# Email (Gmail SMTP) — use Gmail app password
SENTINEL_EMAIL=your_email@gmail.com
SENTINEL_EMAIL_PASSWORD=your_app_password
SENTINEL_RECEIVER=your_email@gmail.com

# Crisis trusted contact link (change if deployed)
SENTINEL_ACK_LINK=http://localhost:8501/trustee

# Groq AI API — free at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# Encryption key (auto-generated if empty)
SENTINEL_ENCRYPTION_KEY=
